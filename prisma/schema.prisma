// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Hunter {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  rank         String   @default("E") // E, D, C, B, A, S, NATIONAL
  xp           Int      @default(0)
  level        Int      @default(1)
  totalQuests  Int      @default(0)
  shadowCount  Int      @default(0)
  strength     Int      @default(10)
  agility      Int      @default(10)
  intelligence Int      @default(10)
  vitality     Int      @default(10)
  perception   Int      @default(10)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdQuests Quest[]      @relation("QuestCreator")
  assignedQuests Quest[]     @relation("QuestAssignee")
  dailyQuests   DailyQuest[]
  ledParties    Party[]      @relation("PartyLeader")
  parties       PartyMember[]
}

model Quest {
  id          String    @id @default(cuid())
  title       String
  description String
  rank        String    @default("E") // E, D, C, B, A, S
  status      String    @default("PENDING") // PENDING, ACTIVE, COMPLETED, FAILED
  xpReward    Int       @default(100)
  isShadow    Boolean   @default(false)
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdById   String
  creator       Hunter  @relation("QuestCreator", fields: [createdById], references: [id])
  assignedToId  String?
  assignee      Hunter? @relation("QuestAssignee", fields: [assignedToId], references: [id])
}

model DailyQuest {
  id        String   @id @default(cuid())
  title     String
  xpReward  Int      @default(50)
  completed Boolean  @default(false)
  date      String   // YYYY-MM-DD
  createdAt DateTime @default(now())

  hunterId  String
  hunter    Hunter @relation(fields: [hunterId], references: [id])
}

model Party {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  leaderId String
  leader   Hunter  @relation("PartyLeader", fields: [leaderId], references: [id])
  members  PartyMember[]
}

model PartyMember {
  id       String @id @default(cuid())
  role     String @default("MEMBER") // MEMBER, VICE_LEADER

  hunterId String
  hunter   Hunter @relation(fields: [hunterId], references: [id])
  partyId  String
  party    Party  @relation(fields: [partyId], references: [id])

  @@unique([hunterId, partyId])
}
